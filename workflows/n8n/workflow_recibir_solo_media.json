    {
      "parameters": {
        "jsCode": "const base64 = $json.base64 || '';\nconst msgData = $('Webhook (Recibir desde Evolution API)1').first().json.body.data.message || {};\nconst mimeType = msgData.imageMessage?.mimetype || msgData.audioMessage?.mimetype || msgData.videoMessage?.mimetype || msgData.documentMessage?.mimetype || 'application/octet-stream';\nconst ext = mimeType.split('/')[1]?.split(';')[0] || 'bin';\nconst fileName = 'media_' + Date.now() + '.' + ext;\n\nitem.binary = {\n  data: {\n    data: base64,\n    mimeType: mimeType,\n    fileName: fileName\n  }\n};\n\nreturn item;"
      },
