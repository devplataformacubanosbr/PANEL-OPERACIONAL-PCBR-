        "jsonBody": "={\n  \"message\": {\n    \"key\": {{ JSON.stringify($('Webhook (Recibir desde Evolution API)1').first().json.body.data.key || {}) }},\n    \"message\": {{ JSON.stringify($('Webhook (Recibir desde Evolution API)1').first().json.body.data.message || {}) }}\n  }\n}",
