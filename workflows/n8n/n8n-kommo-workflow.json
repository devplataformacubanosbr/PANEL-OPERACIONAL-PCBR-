    {
      "parameters": {
        "jsCode": "let idCliente = null;\n\ntry {\n  const data = $('Actualizar Cliente').first().json;\n  idCliente = Array.isArray(data) ? data[0]?.id : data?.id;\n} catch(e) { /* rama no ejecutada */ }\n\nif (!idCliente) {\n  try {\n    const data = $('Crear Cliente').first().json;\n    idCliente = Array.isArray(data) ? data[0]?.id : data?.id;\n  } catch(e) { /* rama no ejecutada */ }\n}\n\nif (!idCliente) throw new Error('No se obtuvo ID del cliente de ninguna rama');\n\nconst datos = $('Mapear Datos Completos').item.json;\n\nreturn [{ json: {\n  id_cliente:     idCliente,\n  id_kommo:       datos.id_kommo,\n  nombre_pix:     datos.nombre_pix,\n  valor:          datos.valor_total,\n  servicio:       datos.tramite,\n  cliente:        datos.nombre,\n  telefono:       datos.telefono,\n  email:          datos.email,\n  pais:           datos.pais,\n  ciudad:         datos.ciudad,\n  estado:         datos.estado,\n  cpf:            datos.cpf,\n  atendente:      datos.atendente,\n  recorrencia:    datos.recorrencia,\n  utm_source:     datos.utm_source,\n  utm_campaign:   datos.utm_campaign,\n  utm_content:    datos.utm_content,\n  utm_medium:     datos.utm_medium,\n  mes:            datos.mes,\n  ano:            datos.ano,\n  fecha:          datos.fecha,\n  estado_tramite: 'pendiente',\n}}];"
      },
