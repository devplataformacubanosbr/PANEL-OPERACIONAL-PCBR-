    },
    {
      "parameters": {
        "jsCode": "const leadData = $input.first().json.data;\nconst lead = typeof leadData === 'string' ? JSON.parse(leadData) : leadData;\n\nconst contactoId = lead._embedded?.contacts?.[0]?.id;\n\nif (!contactoId) {\n  throw new Error('No hay contacto vinculado al lead');\n}\n\nreturn [{\n  json: {\n    contactoId: contactoId,\n    leadId: lead.id,\n    presupuesto: lead.price || 0,\n    leadData: lead\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1184,
        2448
      ],
      "id": "b2bc75cc-7bfc-40fb-9a98-4b1504212011",
      "name": "Extraer contactoId"
    },
    {
      "parameters": {
        "url": "=https://plataformaoficial.kommo.com/api/v4/contacts/{{ $json.contactoId }}?with=custom_fields_values",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": false,
        "options": {}
      },
      "id": "ef38348d-f73a-4882-b90c-3cc96b581eea",
      "name": "Consultar Contacto Kommo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1408,
        2448
      ]
    },
    {
      "parameters": {
        "jsCode": "const contactoRaw = $input.first().json.data;\nconst contacto = typeof contactoRaw === 'string' ? JSON.parse(contactoRaw) : contactoRaw;\n\nconst leadNode = $('Extraer contactoId').item.json;\nconst lead = leadNode.leadData || {};\n\nconst camposContacto = contacto.custom_fields_values || [];\nconst camposLead = lead.custom_fields_values || [];\n\nconst getField = (campos, nombre) => {\n  const field = campos.find(f =>\n    f.field_name?.toLowerCase().includes(nombre.toLowerCase())\n  );\n  return field?.values?.[0]?.value ?? '';\n};\n\nconst telefonoCampo = camposContacto.find(f => f.field_code === 'PHONE');\nconst emailCampo    = camposContacto.find(f => f.field_code === 'EMAIL');\n\nconst now = new Date();\nconst mes = now.getMonth() + 1;\nconst ano = now.getFullYear();\n\nreturn [{ json: {\n  id_kommo:        String(contacto.id || ''),\n  nombre:          lead.name || contacto.name || '',\n  telefono:        telefonoCampo?.values?.[0]?.value || '',\n  email:           emailCampo?.values?.[0]?.value    || '',\n  cpf:             getField(camposContacto, 'cpf'),\n  valor_total:     parseFloat(leadNode.presupuesto)  || 0,\n  pais:            getField(camposLead, 'país origen'),\n  ciudad:          getField(camposLead, 'ciudad'),\n  estado:          getField(camposLead, 'estado'),\n  atendente:       getField(camposLead, 'atendente'),\n  tramite:         getField(camposLead, 'trámite'),\n  nombre_pix:      getField(camposLead, 'nombre pix'),\n  policia_federal: getField(camposLead, 'policia federal'),\n  prioridad:       getField(camposLead, 'prioridad'),\n  recorrencia:     getField(camposLead, 'recorrencia') || 'NUEVO',\n  utm_source:      getField(camposLead, 'utm_source'),\n  utm_campaign:    getField(camposLead, 'utm_campaign'),\n  utm_content:     getField(camposLead, 'utm_content'),\n  utm_medium:      getField(camposLead, 'utm_medium'),\n  id_lead:         String(lead.id || ''),\n  pipeline_id:     String(lead.pipeline_id || ''),\n  status_id:       String(lead.status_id   || ''),\n  mes,\n  ano,\n  fecha:           now.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' }) + ' ' + now.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' }),\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1632,
        2448
      ],
